POSTGRES_USER=postgres
POSTGRES_PASSWORD=tidesense_secret
POSTGRES_DB=tidesense

PROJECT_NAME=TideSense API
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_ALGORITHM=HS256

DB_HOST=db
DB_PORT=5432
DB_NAME=tidesense
DB_USER=postgres
DB_PASSWORD=tidesense_secret
TIMESCALEDB_ENABLED=true

CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
FRONTEND_ORIGIN=http://localhost:5173

EXTERNAL_PROVIDER=mock
NOAA_BASE_URL=https://api.tidesandcurrents.noaa.gov/api/prod/datagetter
NOAA_STATION_MAP={}
TIDECHECK_BASE_URL=https://tidecheck.com
TIDECHECK_API_KEY=replace-with-your-tidecheck-api-key
TIDECHECK_DATUM=MSL
REQUEST_TIMEOUT_SECONDS=20

MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=tidesense

ALERT_WARNING_THRESHOLD_CM=120
ALERT_CRITICAL_THRESHOLD_CM=150

SCHEDULER_ENABLED=true
MOON_UPDATE_INTERVAL_MINUTES=5
PREDICTION_INTERVAL_MINUTES=60
ALERT_CHECK_INTERVAL_MINUTES=5
EXTERNAL_FETCH_INTERVAL_MINUTES=60

BOOTSTRAP_HISTORY_HOURS=72
PREDICTION_HORIZON_HOURS=24
MODEL_ARTIFACTS_DIR=/app/app/ml_artifacts

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000
